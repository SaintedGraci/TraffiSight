# TraffiSight Python AI Environment Variables

# Application
APP_ENV=development
DEBUG=True

# Laravel Integration
LARAVEL_BASE_URL=http://localhost:8000
LARAVEL_API_KEY=your_api_key_here

# Paths
VIDEOS_PATH=../storage/app/public/videos
OUTPUT_PATH=./output
LOGS_PATH=./logs
MODELS_PATH=./models

# GPU Settings
USE_GPU=True
CUDA_VISIBLE_DEVICES=0

# Model Settings
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5

# OCR Settings
EASYOCR_GPU=True
EASYOCR_LANGUAGES=en

# API Settings
API_TIMEOUT=30
API_RETRY=3

# Performance
NUM_THREADS=4
BATCH_SIZE=32
